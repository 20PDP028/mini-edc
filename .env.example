# ── Mini EDC — Environment Variables Template ─────────────────────────────────
# Copy this to .env and fill in your values
# NEVER commit .env to Git — it's in .gitignore

# Security
EDC_SECRET_KEY=change_this_to_a_long_random_string_in_production
EDC_LOG_LEVEL=info          # debug | info | warning | error

# App
EDC_ENV=development         # development | production
EDC_PORT=8000
EDC_WORKERS=2               # number of uvicorn workers

# Optional: Database (for production — replaces in-memory store)
# DATABASE_URL=postgresql://user:password@localhost:5432/mini_edc

# Optional: SMTP for email notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password
