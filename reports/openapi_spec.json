        "tags": [
          "auth"
        ],
        "summary": "Login and receive an auth token",
        "description": "Authenticate with username and password.\n\nReturns a **token** to pass as `?token=` on all protected endpoints.\n\n**Demo credentials:**\n| Username | Password | Role |\n|----------|----------|------|\n| admin | Admin@1234 | Admin |\n| investigator | Invest@1234 | Investigator |\n| datamanager | DataMgr@1234 | Data Manager |\n| monitor | Monitor@1234 | Monitor |",
        "operationId": "login_auth_login_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
