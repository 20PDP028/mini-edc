              ],
              "description": "Filter by CDISC domain",
              "title": "Domain"
            },
            "description": "Filter by CDISC domain"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "description": "Max entries to return",
              "default": 50,
              "title": "Limit"
            },
            "description": "Max entries to return"
          },
