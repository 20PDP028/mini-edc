    "/audit/trail": {
      "get": {
        "tags": [
          "audit"
        ],
        "summary": "Retrieve the immutable 21 CFR Part 11 audit trail",
        "description": "Returns the **hash-chained, tamper-evident audit log** (21 CFR Part 11 \u00a711.10(e)).\n\nEach entry carries a HMAC chain hash linking it to the previous entry.\nAny modification to a historical record breaks the chain and is immediately detectable.",
        "operationId": "get_audit_trail_audit_trail_get",
        "parameters": [
          {
            "name": "user",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by username",
